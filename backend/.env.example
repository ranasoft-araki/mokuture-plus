# Copy to .env and fill in values. Never commit .env to git.

# App
DEBUG=true

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./mokuture.db
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-use-256bit-random

# Storage (MinIO for local dev, Cloudflare R2 for production)
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_BUCKET_NAME=mokuture
STORAGE_PUBLIC_URL=http://localhost:9000/mokuture

# Encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-with-Fernet

# CORS (comma-separated)
ALLOWED_ORIGINS=["http://localhost:3000"]

# VAPID for Web Push (optional in Phase 0)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@mokuture.jp
