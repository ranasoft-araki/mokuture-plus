# ---- Neon PostgreSQL ----
DATABASE_URL=postgresql+asyncpg://neondb_owner:<PASSWORD>@ep-weathered-haze-angdwmej.c-6.us-east-1.aws.neon.tech/neondb?ssl=require

# ---- JWT ----
JWT_SECRET_KEY=<256-bit random hex: python3 -c "import secrets; print(secrets.token_hex(32))">
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ---- Fernet encryption ----
ENCRYPTION_KEY=<base64: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# ---- Cloudflare R2 ----
STORAGE_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=<R2_ACCESS_KEY>
STORAGE_SECRET_ACCESS_KEY=<R2_SECRET_KEY>
STORAGE_BUCKET_NAME=mokuture
STORAGE_PUBLIC_URL=https://pub-<...>.r2.dev/mokuture

# ---- CORS ----
ALLOWED_ORIGINS=["https://mokuture-plus.netlify.app"]

# ---- Misc ----
DEBUG=false
