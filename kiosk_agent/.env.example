# mokuture+ Kiosk Agent 設定ファイル
# .env にコピーして使用してください
#
# ※ デバイストークンはここには書きません。
#   起動後に管理画面の PIN を使って登録します:
#   curl -X POST http://localhost:8080/setup \
#        -H "Content-Type: application/json" \
#        -d '{"pin_code":"123456"}'
#   → device_state.json に保存され、以後自動的に使用されます。

# リモート API エンドポイント
REMOTE_API_URL=https://mokuture-plus-api.onrender.com/api

# ローカルメディアキャッシュ保存先
# RPi: /home/pi/kiosk-media
# 開発機 (非RPi): /tmp/kiosk-media
MEDIA_DIR=/home/pi/kiosk-media

# エージェントがリッスンするポート (Chromium は http://localhost:8080 を開く)
PORT=8080

# コンテンツ同期間隔 (秒)
SYNC_INTERVAL_SEC=60

# GPIO モック (Raspberry Pi 以外の開発機では true に設定)
MOCK_GPIO=false

# PIR 人感センサーの GPIO ピン番号 (BCM)
PIR_PIN=4

# ロッカーとGPIOピンの対応 (locker_id → BCM pin)
# 例: {"1": 17, "2": 18}
LOCKER_PINS_JSON={}
