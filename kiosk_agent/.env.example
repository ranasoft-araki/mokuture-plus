# mokuture+ Kiosk Agent 設定ファイル
# .env にコピーして使用してください

# リモート API エンドポイント
REMOTE_API_URL=https://mokuture-plus-api.onrender.com/api

# 管理画面の「デバイス管理」で発行したデバイストークン
DEVICE_TOKEN=

# ローカルメディアキャッシュ保存先
MEDIA_DIR=/home/pi/kiosk-media

# エージェントがリッスンするポート (Chromium は http://localhost:8080 を開く)
PORT=8080

# コンテンツ同期間隔 (秒)
SYNC_INTERVAL_SEC=60

# GPIO モック (Raspberry Pi 以外の開発機では true に設定)
MOCK_GPIO=false

# PIR 人感センサーの GPIO ピン番号 (BCM)
PIR_PIN=4

# ロッカーとGPIOピンの対応 (locker_id → BCM pin)
# 例: {"1": 17, "2": 18}
LOCKER_PINS_JSON={}
